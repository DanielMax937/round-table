// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Persona {
  id            String   @id @default(cuid())
  name          String
  description   String
  systemPrompt  String
  descriptionZh String?  // Optional Chinese version of description
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agents Agent[]

  @@index([isDefault])
}

model RoundTable {
  id                String   @id @default(cuid())
  topic             String
  agentCount        Int
  maxRounds         Int      @default(5)
  status            String   @default("active") // "active" | "paused" | "archived"
  language          String   @default("zh") // "en" | "zh"
  selectedAgentIds  String?  // JSON array of selected persona IDs
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  agents         Agent[]
  rounds         Round[]
  moeVoteJob     MoeVoteJob?
  discussionJob  DiscussionJob?
  scene          Scene?
}

model MoeVoteJob {
  id                              String   @id @default(cuid())
  status                          String   // "pending" | "running" | "completed" | "failed"
  question                        String
  includeDiscussionAgentsInVoting Boolean  @default(false)
  agentCount                      Int      @default(3)

  // References ephemeral round table
  roundTableId                    String   @unique
  roundTable                      RoundTable @relation(fields: [roundTableId], references: [id], onDelete: Cascade)

  // Progress tracking
  currentRound                    Int?
  currentPhase                    String?  // "discussion" | "voting" | "aggregating"

  // Results (JSON stringified)
  result                          String?
  error                           String?

  // Timestamps
  createdAt                       DateTime @default(now())
  startedAt                       DateTime?
  completedAt                     DateTime?

  @@index([status])
  @@index([createdAt])
}

model Agent {
  id           String  @id @default(cuid())
  roundTableId String
  personaId    String? // Optional reference to Persona
  name         String
  persona      String  // System prompt defining role/perspective
  order        Int     // Turn order (1, 2, 3...)

  roundTable RoundTable @relation(fields: [roundTableId], references: [id], onDelete: Cascade)
  personaRef Persona?   @relation(fields: [personaId], references: [id], onDelete: SetNull)
  messages   Message[]

  @@index([roundTableId])
  @@index([personaId])
}

model Round {
  id           String    @id @default(cuid())
  roundTableId String
  roundNumber  Int
  status       String    @default("in_progress") // "in_progress" | "completed"
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  roundTable RoundTable @relation(fields: [roundTableId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@index([roundTableId])
}

model Message {
  id        String   @id @default(cuid())
  roundId   String
  agentId   String
  content   String   // The agent's response
  toolCalls String?  // JSON array of web searches performed
  citations String?  // JSON array of {url, title, usedInContext} objects
  createdAt DateTime @default(now())

  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@index([agentId])
}

model SearchCache {
  id        String   @id @default(cuid())
  query     String   @unique
  results   String   // JSON string: Array of EnrichedSearchResult
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])  // For efficient cleanup
}

model DiscussionJob {
  id           String   @id @default(cuid())
  status       String   // "pending" | "running" | "completed" | "failed"
  topic        String
  agentCount   Int
  maxRounds    Int      @default(5)
  
  // References round table
  roundTableId String   @unique
  roundTable   RoundTable @relation(fields: [roundTableId], references: [id], onDelete: Cascade)
  
  // Progress tracking
  currentRound Int?
  currentPhase String?  // "discussion" | "completed"
  
  // Error tracking
  error        String?
  
  // Timestamps
  createdAt    DateTime @default(now())
  startedAt    DateTime?
  completedAt  DateTime?

  @@index([status])
  @@index([createdAt])
}

model Movie {
  id                 String   @id @default(cuid())
  title              String
  description        String?
  status             String   @default("active") // "active" | "archived"
  theme              String?  // User input theme (e.g. 赛博朋克、复仇、爱情喜剧)
  storyProposalJson  String?  // Selected story proposal: { oneLiner, coreConflict, styleReference, synopsis }
  storyProposalsJson String?  // All 3 proposals before selection
  plotSummary        String?  // Accumulated plot summary across scenes
  workflowPhase      String   @default("theme") // theme|proposals|story_confirmed|characters|outline|scene_execution|completed
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  characters   Character[]
  scenes       Scene[]
  sceneOutlines SceneOutline[]
  sceneExecutionJobs SceneExecutionJob[]
  visualAssetJobs VisualAssetJob[]
  videoGenerationJobs VideoGenerationJob[]
  qualityReviewJobs QualityReviewJob[]
  productionPipelineRuns ProductionPipelineRun[]
}

model ProductionPipelineRun {
  id             String   @id @default(cuid())
  status         String   @default("pending") // "pending"|"running"|"completed"|"failed"
  movieId        String
  level          String   // "quick"|"director"|"producer"
  sceneIdsJson   String   @default("[]")
  optionsJson    String   @default("{}")
  resultJson     String?
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([movieId])
  @@index([level])
  @@index([status])
  @@index([createdAt])
}

model Character {
  id                    String   @id @default(cuid())
  movieId               String
  name                  String
  backstory             String
  personalityTraits     String
  surfaceGoal           String?  // 表层目标
  deepMotivation        String?  // 深层动机
  fatalFlaw             String?  // 致命弱点
  signatureLanguageStyle String? // 标志性语言风格
  currentStateJson      String?  // { emotionalState, physicalState, knowledge[] } - updated per scene
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  movie           Movie            @relation(fields: [movieId], references: [id], onDelete: Cascade)
  sceneCharacters SceneCharacter[]
  visualAssetJobs VisualAssetJob[]

  @@index([movieId])
}

model SceneOutline {
  id               String   @id @default(cuid())
  movieId          String
  sortOrder        Int
  title            String
  contentSummary   String
  emotionalGoal    String
  characterIdsJson String   // JSON array of character IDs
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  movie Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  scene Scene?
  executionJobs SceneExecutionJob[]

  @@index([movieId])
}

model VisualAssetJob {
  id             String   @id @default(cuid())
  status         String   @default("pending") // "pending"|"running"|"completed"|"failed"
  movieId        String
  sceneId        String?
  characterId    String?
  assetType      String   // "comic"|"storyboard"|"character_look"|"keyframe"|"environment"
  stylesJson     String   // JSON array, e.g. ["live_action","cg_animation"]
  title          String
  prompt         String   // English imagegen prompt
  codexPrompt    String   // Chinese Codex prompt using imagegen
  codexCommand   String   // Display command requested by user: codex -p "..."
  executionCommand String? // Actual local CLI command used when run=true
  result         String?
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  movie     Movie      @relation(fields: [movieId], references: [id], onDelete: Cascade)
  scene     Scene?     @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  videoGenerationJobs VideoGenerationJob[]
  qualityReviewJobs QualityReviewJob[]

  @@index([movieId])
  @@index([sceneId])
  @@index([characterId])
  @@index([status])
  @@index([createdAt])
}

model VideoGenerationJob {
  id             String   @id @default(cuid())
  status         String   @default("pending") // "pending"|"running"|"completed"|"failed"
  movieId        String
  sceneId        String?
  visualAssetJobId String?
  title          String
  ratio          String   @default("16:9")
  durationSeconds Int?
  sourceImagePathsJson String @default("[]")
  prompt         String   // English image-to-video / text-to-video prompt
  doubaoInputJson String // JSON array item compatible with doubao-video-task
  inputJsonPath  String?
  doubaoCommand  String  // Display command for the external doubao runner
  executionCommand String?
  outputDir      String?
  result         String?
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  movie          Movie           @relation(fields: [movieId], references: [id], onDelete: Cascade)
  scene          Scene?          @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  visualAssetJob VisualAssetJob? @relation(fields: [visualAssetJobId], references: [id], onDelete: SetNull)
  qualityReviewJobs QualityReviewJob[]

  @@index([movieId])
  @@index([sceneId])
  @@index([visualAssetJobId])
  @@index([status])
  @@index([createdAt])
}

model QualityReviewJob {
  id             String   @id @default(cuid())
  status         String   @default("pending") // "pending"|"running"|"completed"|"failed"
  movieId        String
  targetType     String   // "script"|"visual_asset"|"video"
  targetId       String
  sceneId        String?
  visualAssetJobId String?
  videoGenerationJobId String?
  title          String
  score          Int?
  aiFeel         String?
  industryLevel  String?
  passed         Boolean  @default(false)
  summary        String?
  issuesJson     String   @default("[]")
  repairInstructions String?
  resultJson     String?
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  movie          Movie           @relation(fields: [movieId], references: [id], onDelete: Cascade)
  scene          Scene?          @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  visualAssetJob VisualAssetJob? @relation(fields: [visualAssetJobId], references: [id], onDelete: SetNull)
  videoGenerationJob VideoGenerationJob? @relation(fields: [videoGenerationJobId], references: [id], onDelete: SetNull)

  @@index([movieId])
  @@index([targetType])
  @@index([targetId])
  @@index([sceneId])
  @@index([visualAssetJobId])
  @@index([videoGenerationJobId])
  @@index([status])
  @@index([passed])
  @@index([createdAt])
}

model Scene {
  id              String   @id @default(cuid())
  movieId         String
  sceneNumber     Int
  heading         String
  description     String
  status          String   @default("active") // "outline"|"ready"|"draft"|"confirmed"|"finalized"
  finalizedScript String?
  maxRounds       Int      @default(10)
  roundTableId    String   @unique
  contentSummary  String?
  emotionalGoal   String?
  contextJson     String?  // Scene context when entering (goal, character states)
  settlementSummary String? // After scene: plot summary addition, character state updates
  sceneOutlineId String?   @unique // Link to SceneOutline if created from outline
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  movie          Movie            @relation(fields: [movieId], references: [id], onDelete: Cascade)
  roundTable     RoundTable       @relation(fields: [roundTableId], references: [id], onDelete: Cascade)
  sceneOutline   SceneOutline?    @relation(fields: [sceneOutlineId], references: [id])
  sceneCharacters SceneCharacter[]
  executionJobs SceneExecutionJob[]
  visualAssetJobs VisualAssetJob[]
  videoGenerationJobs VideoGenerationJob[]
  qualityReviewJobs QualityReviewJob[]

  @@index([movieId])
}

model SceneExecutionJob {
  id             String   @id @default(cuid())
  status         String   // "pending" | "running" | "completed" | "failed"
  movieId        String
  sceneOutlineId String?
  sceneId        String?
  outlineIndex   Int

  currentRound     Int?
  currentAgentName String?
  currentPhase     String? // "queued"|"creating_scene"|"director"|"rounds"|"synthesizing"|"completed"

  result         String? // JSON stringified { sceneId, fullScript, messageCount }
  error          String?

  createdAt      DateTime @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  updatedAt      DateTime @updatedAt

  movie        Movie         @relation(fields: [movieId], references: [id], onDelete: Cascade)
  sceneOutline SceneOutline? @relation(fields: [sceneOutlineId], references: [id], onDelete: SetNull)
  scene        Scene?        @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  @@index([movieId])
  @@index([sceneOutlineId])
  @@index([sceneId])
  @@index([status])
  @@index([createdAt])
}

model SceneCharacter {
  id          String @id @default(cuid())
  sceneId     String
  characterId String
  order       Int

  scene     Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([sceneId, characterId])
  @@index([sceneId])
  @@index([characterId])
}
