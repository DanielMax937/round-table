# Database
DATABASE_URL="file:./dev.db"

# OpenAI Configuration (required for LLM calls)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="your-api-key-here"
# Optional: Custom API endpoint (leave unset for standard OpenAI API)
# OPENAI_BASE_URL="https://api.openai.com/v1"
# Optional: Model to use (default: gpt-4-turbo)
# OPENAI_MODEL_NAME="gpt-4-turbo"

# Serper API Key (required for web search)
# Get your free API key from: https://serper.dev/
# Free tier: 2,500 searches/month
SERPER_API_KEY="your-serper-api-key-here"

# Jina AI Reader API Key (optional - improves content enrichment)
# Get your free API key from: https://jina.ai/reader
# Without key: limited access, may return 401 errors
# With key: higher rate limits and better reliability
JINA_API_KEY="your-jina-api-key-here"

# Telegram notifications (AI Movie workflow - optional)
# Config from project .env only, no external fallback
# CTI_TG_BOT_TOKEN=your-bot-token
# CTI_TG_CHAT_ID=your-chat-id
# CTI_PROXY=http://127.0.0.1:1087
# TELEGRAM_DISABLED=true   # Set to true/1/yes to disable all Telegram notifications
